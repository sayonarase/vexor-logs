# Vexor Logs runtime environment.
# On the Vexor server this points to the local VictoriaLogs instance.
# On hosts running an agent (vector or fluent-bit), point this at the
# Vexor server IP/hostname on TCP 9428.
VEXOR_LOGS_URL=http://127.0.0.1:9428
VEXOR_LOGS_HOST=127.0.0.1
VEXOR_LOGS_PORT=9428
# Optional bearer token forwarded to VictoriaLogs (none for MVP)
# VEXOR_LOGS_TOKEN=

# Log retention in days. Applied by the vexor-victorialogs launcher.
VEXOR_LOGS_RETENTION_DAYS=90
