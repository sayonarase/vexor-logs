// Allow vexor user (running vexor-api) to restart vexor-victorialogs
// without needing sudo (NoNewPrivileges=true on vexor-api breaks sudo).
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "vexor") {
        var unit = action.lookup("unit");
        if (unit == "vexor-victorialogs.service") {
            return polkit.Result.YES;
        }
    }
});
